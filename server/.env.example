DATABASE_URL=postgres://username:password@localhost:5432/goal_tracker
PORT=3001

# Bcrypt hash of your chosen password (see setup steps below for how to generate this)
# node -e "console.log(require('bcryptjs').hashSync('your-password-here', 10))"
APP_PASSWORD_HASH= paste-the-result-here

# A long random string used to sign login tokens
# Setup steps
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET= paste-the-result-here
